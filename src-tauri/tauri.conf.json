{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Trackly",
  "version": "0.4.0",
  "identifier": "com.trackly.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "app": {
    "windows": [
      {
        "title": "Trackly",
        "width": 1160,
        "height": 760,
        "minWidth": 880,
        "minHeight": 560
      }
    ],
    "security": {
      "csp": null
    }
  }
}